# Copy this file to `.env.local` and fill in real values.
# `.env.local` is git-ignored and must never be committed.

# MongoDB connection string (MongoDB Atlas → Connect → Drivers)
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>/manta-bali-nusa-tours?retryWrites=true&w=majority"

# Admin login for the /studio dashboard
STUDIO_EMAIL="you@example.com"
STUDIO_PASSWORD="use-a-long-random-password"

# Secret for signing the admin session cookie.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="a-long-random-hex-string"
